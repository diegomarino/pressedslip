{
  "name": "pressedslip-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prerender:hero": "tsx scripts/pre-render-hero.mjs",
    "build": "pnpm prerender:hero && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "serve": "pnpm build && pnpm preview",
    "dev": "vite --port 4173 --strictPort",
    "test": "vitest run src",
    "test:smoke": "playwright test",
    "verify": "pnpm test && pnpm build && tsx scripts/verify-variants.mjs && node ../../scripts/check-bundle-size.mjs && start-server-and-test 'vite preview --port 4173 --strictPort' http://localhost:4173 'playwright test'"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.0",
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lezer/common": "^1.5.2",
    "@lezer/json": "^1.0.2",
    "@uiw/react-codemirror": "^4.23.0",
    "jsonc-parser": "^3.3.1",
    "pressedslip": "workspace:*",
    "react": "^19",
    "react-dom": "^19",
    "react-resizable-panels": "^2.1.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "start-server-and-test": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4"
  }
}
